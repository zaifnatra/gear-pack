# Copy this file to .env and fill in the real values.
# Never commit .env — it is gitignored.

# PostgreSQL connection string (Supabase pooler)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres"

# Direct connection (used by Prisma for migrations / shadow DB)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres"

# Supabase project credentials
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Database password (used separately if needed)
DATABASE_PASSWORD=your-database-password

# Google OAuth
GOOGLE_AUTH_CLIENTSECRET=your-google-oauth-client-secret

# Backboard AI
BACKBOARD_API_KEY="your-backboard-api-key"
BACKBOARD_ASSISTANT_ID=your-backboard-assistant-uuid
BACKBOARD_SCOPE_ASSISTANT_ID=your-backboard-scope-assistant-uuid
BACKBOARD_API_URL=https://app.backboard.io/api
